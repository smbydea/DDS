{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "stlinkgdbtarget",
            "request": "launch",
            "name": "STM32Cube: ST-Link SWD Slow Software Reset",
            "origin": "snippet",
            "cwd": "${workspaceFolder}",
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",
            "runEntry": "main",
            "serverInterface": "SWD",
            "serverInterfaceFrequency": "140",
            "serverReset": "Software system reset",
            "serverPendingHaltTimeout": "10",
            "serverVerify": true,
            "serverRtos": {
                "enabled": false
            },
            "automaticallyKillServer": true,
            "verbose": true,
            "imagesAndSymbols": [
                {
                    "imageFileName": "${command:st-stm32-ide-debug-launch.get-projects-binary-from-context1}"
                }
            ]
        },
        {
            "type": "stlinkgdbtarget",
            "request": "launch",
            "name": "STM32Cube: ST-Link SWD Slow No Reset",
            "origin": "snippet",
            "cwd": "${workspaceFolder}",
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",
            "runEntry": "main",
            "serverInterface": "SWD",
            "serverInterfaceFrequency": "140",
            "serverReset": "None",
            "serverPendingHaltTimeout": "10",
            "serverVerify": true,
            "serverRtos": {
                "enabled": false
            },
            "automaticallyKillServer": true,
            "verbose": true,
            "imagesAndSymbols": [
                {
                    "imageFileName": "${command:st-stm32-ide-debug-launch.get-projects-binary-from-context1}"
                }
            ]
        }
    ]
}
